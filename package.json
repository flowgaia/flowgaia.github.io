{
  "name": "flowgaia-music-player",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run watch:wasm\" \"npm run dev:vite\"",
    "dev:vite": "vite",
    "watch:wasm": "cargo watch -C rust-core --ignore pkg -s 'wasm-pack build rust-core --target web --out-dir ../wasm --dev'",
    "build": "npm run build:wasm && vite build",
    "build:wasm": "wasm-pack build rust-core --target web --out-dir ../wasm",
    "preview": "vite preview",
    "test:rust": "cargo test --manifest-path rust-core/Cargo.toml",
    "test:coverage": "cargo tarpaulin --manifest-path rust-core/Cargo.toml --out Xml --output-dir coverage",
    "generate:music": "node scripts/generate-music-json.js"
  },
  "dependencies": {
    "sortablejs": "^1.15.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "concurrently": "^8.2.0",
    "js-yaml": "^4.1.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.0.0",
    "vite-plugin-top-level-await": "^1.4.0",
    "vite-plugin-wasm": "^3.3.0"
  }
}
